# ──────────────────────────────────────────────
# Conexión a PostgreSQL
# ──────────────────────────────────────────────

# Host de la base de datos:
#   - Local sin Docker:              localhost
#   - Local con Docker (Windows/Mac): host.docker.internal
#   - Local con Docker (Linux):       172.17.0.1  (IP del bridge docker0)
#   - Producción:                     IP o hostname del servidor de BD
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eleccionesdb
DB_USER=eleccionesdb_api
DB_PASSWORD=changeme
DB_SCHEMA=

# ──────────────────────────────────────────────
# Configuración de la aplicación
# ──────────────────────────────────────────────

# Entorno: development | production
APP_ENV=development

# root_path para reverse proxy (Nginx).
# Si Nginx sirve la API en https://midominio.com/api,
# entonces ROOT_PATH=/api
# Si la API está en la raíz, déjalo vacío.
ROOT_PATH=
