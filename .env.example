# ──────────────────────────────────────────────
# Conexión a PostgreSQL
# ──────────────────────────────────────────────

# Host de la base de datos:
#   - Local sin Docker:              localhost
#   - Local con Docker (Windows/Mac): host.docker.internal
#   - Local con Docker (Linux):       172.17.0.1  (IP del bridge docker0)
#   - Producción:                     IP o hostname del servidor de BD
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eleccionesdb
DB_USER=eleccionesdb_api
DB_PASSWORD=changeme
DB_SCHEMA=

# ──────────────────────────────────────────────
# Configuración de la aplicación
# ──────────────────────────────────────────────

# Entorno: development | production
APP_ENV=development

# root_path para reverse proxy (Nginx).
# Si Nginx sirve la API en https://midominio.com/api,
# entonces ROOT_PATH=/api
# Si la API está en la raíz, déjalo vacío.
ROOT_PATH=

# ──────────────────────────────────────────────
# Autenticación y API keys
# ──────────────────────────────────────────────

# BD SQLite para el sistema de auth (separada de PostgreSQL).
# En Docker se persiste en el volumen auth-data montado en /app/data.
AUTH_DB_URL=sqlite:///data/auth.db

# URL base pública de la API (para construir enlaces de verificación).
APP_BASE_URL=http://localhost:8000

# ──────────────────────────────────────────────
# Resend (email transaccional)
# ──────────────────────────────────────────────

# API key de Resend (https://resend.com/api-keys).
# Si está vacío, los emails no se envían (se loguea una advertencia).
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

# ──────────────────────────────────────────────
# Límites de tasa y verificación (opcionales, valores por defecto razonables)
# ──────────────────────────────────────────────

# VERIFICATION_TOKEN_EXPIRY_HOURS=24
# API_KEY_ROTATION_GRACE_HOURS=1
# RATE_LIMIT_REGISTER_PER_IP=5
# RATE_LIMIT_REGISTER_PER_EMAIL=3
